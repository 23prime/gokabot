# Copy this file to .env and fill in your values.

# LINE Bot credentials (required)
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_TOKEN=your_line_channel_access_token_here

# OpenWeatherMap API key (optional; weather answerer returns error without it)
OPEN_WEATHER_API_KEY=your_openweathermap_api_key_here

# LINE user ID whose messages are learned by the Gokabou Markov chain (optional)
GOKABOU_USER_ID=your_line_user_id_here

# Target LINE user ID for integration tests (e.g. your own LINE user ID)
LINE_PUSH_TARGET_ID=your_line_user_id_here
